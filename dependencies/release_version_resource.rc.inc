#include <winver.h>

#ifndef AIP_VERSION_MAJOR
#define AIP_VERSION_MAJOR 1
#endif

#ifndef AIP_VERSION_MINOR
#define AIP_VERSION_MINOR 0
#endif

#ifndef AIP_VERSION_BUILD
#define AIP_VERSION_BUILD 0
#endif

#ifndef AIP_VERSION_REVISION
#define AIP_VERSION_REVISION 0
#endif

#ifndef AIP_FILE_DESCRIPTION
#define AIP_FILE_DESCRIPTION "AIProjects application"
#endif

#ifndef AIP_INTERNAL_NAME
#define AIP_INTERNAL_NAME "application.exe"
#endif

#ifndef AIP_ORIGINAL_FILENAME
#define AIP_ORIGINAL_FILENAME "application.exe"
#endif

#ifndef AIP_COMPANY_NAME
#define AIP_COMPANY_NAME "AIProjects"
#endif

#ifndef AIP_PRODUCT_NAME
#define AIP_PRODUCT_NAME "AIProjects application"
#endif

#define AIP_VERSION_COMMA AIP_VERSION_MAJOR,AIP_VERSION_MINOR,AIP_VERSION_BUILD,AIP_VERSION_REVISION
#define AIP_RELEASE_RC_STRINGIZE2(x) #x
#define AIP_RELEASE_RC_STRINGIZE(x) AIP_RELEASE_RC_STRINGIZE2(x)
#define AIP_VERSION_TEXT \
    AIP_RELEASE_RC_STRINGIZE(AIP_VERSION_MAJOR) "." \
    AIP_RELEASE_RC_STRINGIZE(AIP_VERSION_MINOR) "." \
    AIP_RELEASE_RC_STRINGIZE(AIP_VERSION_BUILD) "." \
    AIP_RELEASE_RC_STRINGIZE(AIP_VERSION_REVISION)

1 VERSIONINFO
FILEVERSION AIP_VERSION_COMMA
PRODUCTVERSION AIP_VERSION_COMMA
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0x0L
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", AIP_COMPANY_NAME "\0"
            VALUE "FileDescription", AIP_FILE_DESCRIPTION "\0"
            VALUE "FileVersion", AIP_VERSION_TEXT "\0"
            VALUE "InternalName", AIP_INTERNAL_NAME "\0"
            VALUE "OriginalFilename", AIP_ORIGINAL_FILENAME "\0"
            VALUE "ProductName", AIP_PRODUCT_NAME "\0"
            VALUE "ProductVersion", AIP_VERSION_TEXT "\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
