* text=auto

*.cpp text eol=crlf
*.inc text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.cs text eol=crlf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.gitignore text eol=lf

# Keep source archives free of local/runtime/build artifacts.
.gitignore export-ignore
.github/build/ export-ignore
**/build/ export-ignore
**/references/ export-ignore
**/*.log export-ignore
**/*.ini export-ignore
**/*.tmp export-ignore
**/*.bak export-ignore
**/*.obj export-ignore
**/*.exe export-ignore
**/*.pdb export-ignore
**/*.ilk export-ignore
**/*.res export-ignore
**/*.sha256 export-ignore
**/*.zip export-ignore
LOCAL_TOOL_INVENTORY.md export-ignore
