#include <winver.h>

#ifndef DESKTOPSTUB_VERSION_MAJOR
#define DESKTOPSTUB_VERSION_MAJOR 1
#endif

#ifndef DESKTOPSTUB_VERSION_MINOR
#define DESKTOPSTUB_VERSION_MINOR 0
#endif

#ifndef DESKTOPSTUB_VERSION_BUILD
#define DESKTOPSTUB_VERSION_BUILD 0
#endif

#ifndef DESKTOPSTUB_VERSION_REVISION
#define DESKTOPSTUB_VERSION_REVISION 0
#endif

#ifndef DESKTOPSTUB_FILE_DESCRIPTION
#define DESKTOPSTUB_FILE_DESCRIPTION "DesktopStub"
#endif

#ifndef DESKTOPSTUB_INTERNAL_NAME
#define DESKTOPSTUB_INTERNAL_NAME "DesktopStub.exe"
#endif

#ifndef DESKTOPSTUB_ORIGINAL_FILENAME
#define DESKTOPSTUB_ORIGINAL_FILENAME "DesktopStub.exe"
#endif

#ifndef DESKTOPSTUB_COMPANY_NAME
#define DESKTOPSTUB_COMPANY_NAME "DesktopStub"
#endif

#ifndef DESKTOPSTUB_PRODUCT_NAME
#define DESKTOPSTUB_PRODUCT_NAME "DesktopStub"
#endif

#define DESKTOPSTUB_VERSION_COMMA DESKTOPSTUB_VERSION_MAJOR,DESKTOPSTUB_VERSION_MINOR,DESKTOPSTUB_VERSION_BUILD,DESKTOPSTUB_VERSION_REVISION
#define DESKTOPSTUB_RC_STRINGIZE2(x) #x
#define DESKTOPSTUB_RC_STRINGIZE(x) DESKTOPSTUB_RC_STRINGIZE2(x)
#define DESKTOPSTUB_VERSION_TEXT \
    DESKTOPSTUB_RC_STRINGIZE(DESKTOPSTUB_VERSION_MAJOR) "." \
    DESKTOPSTUB_RC_STRINGIZE(DESKTOPSTUB_VERSION_MINOR) "." \
    DESKTOPSTUB_RC_STRINGIZE(DESKTOPSTUB_VERSION_BUILD) "." \
    DESKTOPSTUB_RC_STRINGIZE(DESKTOPSTUB_VERSION_REVISION)

1 VERSIONINFO
FILEVERSION DESKTOPSTUB_VERSION_COMMA
PRODUCTVERSION DESKTOPSTUB_VERSION_COMMA
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0x0L
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", DESKTOPSTUB_COMPANY_NAME "\0"
            VALUE "FileDescription", DESKTOPSTUB_FILE_DESCRIPTION "\0"
            VALUE "FileVersion", DESKTOPSTUB_VERSION_TEXT "\0"
            VALUE "InternalName", DESKTOPSTUB_INTERNAL_NAME "\0"
            VALUE "OriginalFilename", DESKTOPSTUB_ORIGINAL_FILENAME "\0"
            VALUE "ProductName", DESKTOPSTUB_PRODUCT_NAME "\0"
            VALUE "ProductVersion", DESKTOPSTUB_VERSION_TEXT "\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
