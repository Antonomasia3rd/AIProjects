# User-local and generated files
*.log
*.ini
!*.example.ini
*.tmp
*.bak
*.user
*.suo
*.pdb
*.sha256

# Build products: ignore every build directory, regardless of project/location.
# Examples: DesktopStub/build/, DiscordRPC/build/, legacy/*/build/, .github/build/.
**/build/

# Local/reference/vendor scratch folders; keep only source files in git unless explicitly vendored.
**/references/
**/bin/
**/obj/

# Local inventories and private runtime configuration
LOCAL_TOOL_INVENTORY.md

# Project-specific local/runtime files outside build/
legacy/TaskSchedulerMigration/TaskSchedulerMigrationBackup/
legacy/SecureDesktopLauncher/*.ini
legacy/RealTimeNotesDeskband/*.dll
legacy/RealTimeNotesDeskband/*_cookie.json
